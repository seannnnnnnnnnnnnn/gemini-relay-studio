# Copy this file to .env and fill in your token.
ONEAPI_BASE_URL=https://oneapi.keath.ai
ONEAPI_API_KEY=sk-your-key

# OpenAI-compatible routes are the default for New API / OneAPI panels.
TEXT_API_MODE=openai
IMAGE_API_MODE=auto
VIDEO_API_MODE=auto

TEXT_MODEL=gemini-3.1-pro-preview
FAST_TEXT_MODEL=gemini-3.1-preview
VISION_MODEL=gemini-3.1-pro-preview
IMAGE_MODEL=gemini-3.1-flash-image-preview
VIDEO_MODEL=veo-3.1-generate-001
VIDEO_FAST_MODEL=veo-3.0-fast-generate-001
VIDEO_LITE_MODEL=veo-3.1-lite-generate-preview
VIDEO_FALLBACK_MODEL=veo-3.0-generate-001

# Override these only if your OneAPI panel exposes different video routes.
OPENAI_CHAT_PATH=/v1/chat/completions
IMAGE_CHAT_PATH=/v1/chat/completions
VIDEO_CREATE_PATH=/v1/video/generations
VIDEO_OPENAI_CREATE_PATH=/v1/videos
VIDEO_POLL_PATHS=/v1/video/generations/{id},/v1/videos/{id}

PORT=4310
HOST=127.0.0.1
REQUEST_TIMEOUT_MS=180000
IMAGE_REQUEST_TIMEOUT_MS=300000
ASSET_DOWNLOAD_TIMEOUT_MS=600000
VIDEO_SAVE_RETRY_DELAYS_MS=0,5000,15000,30000,60000
VIDEO_POLL_INTERVAL_MS=10000
VIDEO_MAX_POLLS=90
